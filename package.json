{
  "name": "mikumikuar",
  "private": true,
  "version": "1.6.3",
  "scripts": {
    "gen:status": "node scripts/gen-status-index.mjs",
    "check:status": "node scripts/gen-status-index.mjs --reverse --check",
    "check:docs": "npm run check:status && node scripts/check-doc-drift.mjs",
    "dep:graph": "node scripts/gen-dep-graph.mjs",
    "dep:graph:list": "node scripts/gen-dep-graph.mjs --format list",
    "gen:funcmap": "node scripts/gen-funcmap.mjs",
    "check:funcmap": "node scripts/gen-funcmap.mjs --check",
    "test:scripts": "node --test scripts/_lib/source-graph.test.mjs",
    "test:e2e": "cd frontend && npm run test:e2e",
    "test": "cd frontend && npm test",
    "build": "cd frontend && npm run build",
    "dev": "cd frontend && npx vite --port 9245 --strictPort",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "build:linux": "bash scripts/build-linux.sh",
    "build:android": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 -Arch arm64",
    "build:android:release": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 -Arch arm64 -Production"
  }
}
