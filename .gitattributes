# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code — keep LF on all platforms
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.go    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf

# Windows scripts — keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.icns  binary
*.wasm  binary
*.exe   binary
*.apk   binary
*.zip   binary
*.so    binary
*.dll   binary
*.dylib binary
*.ttf   binary
*.otf   binary
