#!/bin/sh
# MikuMikuAR pre-push — 文档漂移推送前校验（秒级）
# 安装方式: git config core.hooksPath .githooks
# 跳过一次: git push --no-verify（不推荐）

set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "[pre-push] check:status (ADR 索引同步)"
node scripts/gen-status-index.mjs --reverse --check || {
  echo ""
  echo "❌ status.md 与 ADR 源不同步。修复: npm run gen:status && git add docs/status.md"
  exit 1
}

echo "[pre-push] check:funcmap (函数索引同步)"
node scripts/gen-funcmap.mjs --check || {
  echo ""
  echo "❌ function-map.md 与源码不同步。修复: npm run gen:funcmap && git add docs/function-map.md"
  exit 1
}

echo "[pre-push] check:docs (架构树/知识卡/ADR 三向漂移)"
node scripts/check-doc-drift.mjs || {
  echo ""
  echo "❌ 检测到 ERROR 级文档漂移（架构树/知识卡 source_files/ADR 索引）。"
  echo "   查看上方 ERROR 明细，修复后用 'npm run check:docs' 复验（INFO/WARNING 不阻断）。"
  exit 1
}

echo "[pre-push] 全部通过"
