#!/bin/sh
# MikuMikuAR pre-push — 文档漂移推送前校验（秒级）
# 安装方式: git config core.hooksPath .githooks
# 跳过一次: git push --no-verify（不推荐）

set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "[pre-commit] check:status (ADR 索引同步)"
node scripts/gen-status-index.mjs --reverse --check || {
  echo ""
  echo "❌ status.md 与 ADR 源不同步。修复: npm run gen:status && git add docs/status.md"
  exit 1
}

echo "[pre-commit] check:funcmap (函数索引同步)"
node scripts/gen-funcmap.mjs --check || {
  echo ""
  echo "❌ function-map.md 与源码不同步。修复: npm run gen:funcmap && git add docs/function-map.md"
  exit 1
}

echo "[pre-commit] ✅ 全部通过"
